# RadAgent v2 — Environment Variables
# Copy to .env and fill in your API keys

# Featherless API (for vanilla baseline)
FEATHERLESS_API_KEY=your-featherless-api-key-here

# Google Gemini API (for autonomy planner)
GEMINI_API_KEY=your-gemini-api-key-here

# Speechmatics API (for dictation transcription)
SPEECHMATICS_API_KEY=your-speechmatics-api-key-here