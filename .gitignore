# ============================================================
# RadAgent .gitignore
# ============================================================

# --- big binary artifacts (use cloud storage / git-lfs instead) ---
# Note: we DON'T ignore runs/ wholesale — bench result JSONs/logs/md live there.
# Instead we ignore by file type so small text artifacts stay trackable.
*.pt
*.pth
*.ckpt
*.npz
*.faiss
*.parquet
*.safetensors

# big data dirs (datasets, raw RAG sources)
data/nih/
data/rag/raw/

# Per-experiment trash inside runs/ that should never be committed
runs/**/*.png
runs/**/*.jpg
runs/**/*.jpeg
runs/**/checkpoints/
runs/**/tb_logs/
runs/**/tensorboard/
runs/**/wandb/

# --- HF / model caches ---
hf_cache/
.cache/

# --- secrets ---
.env
*.token
*_secret*
amd_radagent
amd_radagent.pub
*.pem

# --- python ---
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- venvs ---
.venv/
venv/
env/

# --- editor / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- logs (top-level scratch logs only — bench result logs under runs/ are kept) ---
/calibrate_bands.log
/predict_one.log
/scrape.log
/build_index.log
/corpus.log
/bench_*.log
/*.log

# --- temp ---
*.tmp
tmp/
temp/
